L1_CHAIN_ID=11155111
L2_CHAIN_ID=61091
CHAIN_NAME=payment-rollup
# Leave these blank unless a specific op-deployer release requires overrides.
OPCM_ADDRESS=
L1_CONTRACTS_LOCATOR=
L2_CONTRACTS_LOCATOR=
# Ethereum Sepolia execution RPC.
L1_RPC_URL=
# Optional deployment-only Sepolia RPC. Useful when a provider rejects large deployment transactions.
L1_DEPLOY_RPC_URL=
# Ethereum Sepolia Beacon API. If publicnode is blocked, use the matching Alchemy Beacon endpoint.
L1_BEACON_URL=https://ethereum-sepolia-beacon-api.publicnode.com
ADMIN_ADDRESS=
# 64 hex chars, with or without 0x. Do not commit real values.
PRIVATE_KEY=
BATCHER_PRIVATE_KEY=
PROPOSER_PRIVATE_KEY=
BATCHER_ADDRESS=
PROPOSER_ADDRESS=
CHALLENGER_ADDRESS=
BASE_FEE_VAULT_RECIPIENT=
L1_FEE_VAULT_RECIPIENT=
SEQUENCER_FEE_VAULT_RECIPIENT=
OPERATOR_FEE_VAULT_RECIPIENT=
CHAIN_FEES_RECIPIENT=
SYSTEM_CONFIG_OWNER=
UNSAFE_BLOCK_SIGNER=
L1_PROXY_ADMIN_OWNER=
L2_PROXY_ADMIN_OWNER=
FUND_DEV_ACCOUNTS=true
USE_INTEROP=false
RPC_PORT=8545
WS_PORT=8546
AUTHRPC_PORT=8551
ROLLUP_RPC_PORT=8547
BATCHER_RPC_PORT=8548
PROPOSER_RPC_PORT=8560
OP_GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101702.2
OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.18.0
OP_BATCHER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-batcher:v1.16.8
OP_PROPOSER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-proposer:v1.16.0
OP_BATCHER_POLL_INTERVAL=1s
OP_BATCHER_SUB_SAFETY_MARGIN=6
OP_BATCHER_NUM_CONFIRMATIONS=1
OP_BATCHER_SAFE_ABORT_NONCE_TOO_LOW_COUNT=3
OP_BATCHER_MAX_CHANNEL_DURATION=1
OP_BATCHER_DATA_AVAILABILITY_TYPE=calldata
OP_BATCHER_THROTTLE_UNSAFE_DA_BYTES_LOWER_THRESHOLD=0
OP_PROPOSER_PROPOSAL_INTERVAL=3600s
OP_PROPOSER_GAME_TYPE=0
OP_PROPOSER_POLL_INTERVAL=20s
OP_PROPOSER_ALLOW_NON_FINALIZED=true
OP_PROPOSER_WAIT_NODE_SYNC=true
